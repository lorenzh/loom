{
  "name": "loom",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --filter './packages/*' build",
    "build:pkg": "bun tools/build-publish-package.ts packages/runtime && bun tools/build-publish-package.ts packages/runner",
    "check": "biome check .",
    "fix": "biome check --write .",
    "format": "biome format --write .",
    "lint": "biome lint ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
